<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PromptLit — Learn AI. Free.</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0a0f; --surface:#111118; --surface2:#1a1a24;
  --border:rgba(255,255,255,0.07); --text:#f0f0f5; --muted:#7a7a9a;
  --accent:#6c63ff; --accent2:#ff6b6b; --accent3:#00d4aa; --yellow:#f7c948;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;}

/* ── PAGES ── */
.page { display:none !important; }
.page.active { padding-bottom: 80px; }
.page.flex-page.active { padding-bottom: 0; }
.page.active { display:block !important; }
.page.flex-page.active { display:flex !important; flex-direction:column; height:100vh; overflow:hidden; }

/* ══════════════════════════════════════
   SHARED NAV
══════════════════════════════════════ */
.topnav{
  position:sticky;top:0;z-index:100;height:52px;
  background:rgba(10,10,15,0.92);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 28px;gap:0;flex-shrink:0;
}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--text);cursor:pointer;text-decoration:none;flex-shrink:0;}
.logo span{color:var(--accent);}
.nav-sep{color:rgba(255,255,255,0.12);font-size:20px;margin:0 4px;}
.nav-crumbs{display:flex;align-items:center;flex:1;overflow:hidden;}
.crumb{
  display:flex;align-items:center;gap:6px;padding:0 14px;height:52px;
  font-size:13px;color:var(--muted);cursor:pointer;white-space:nowrap;
  border-right:1px solid var(--border);transition:color 0.2s,background 0.2s;
}
.crumb:hover{color:var(--text);background:rgba(255,255,255,0.02);}
.crumb.active{color:var(--text);font-weight:500;}
.crumb-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;}
.crumb-dot.done{background:var(--accent3);}
.crumb-dot.cur{background:var(--accent);animation:pulse 2s infinite;}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px;padding-left:12px;}
.pill{display:flex;align-items:center;gap:5px;border-radius:100px;padding:4px 11px;font-size:12px;font-weight:600;}
.pill.xp{background:rgba(247,201,72,0.1);border:1px solid rgba(247,201,72,0.2);color:var(--yellow);}
.pill.streak{background:rgba(255,107,107,0.1);border:1px solid rgba(255,107,107,0.2);color:var(--accent2);}

/* ══════════════════════════════════════
   PAGE 1: HOMEPAGE
══════════════════════════════════════ */
.home-nav{
  position:fixed;top:0;left:0;right:0;z-index:100;height:56px;
  background:rgba(10,10,15,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 40px;
}
.home-nav .logo{margin-right:32px;}
.hnav-links{display:flex;align-items:center;gap:4px;flex:1;}
.hnav-link{padding:6px 14px;height:auto;display:flex;align-items:center;font-size:13px;color:var(--muted);cursor:pointer;border:none;border-radius:7px;transition:color 0.2s,background 0.2s;}
.hnav-link:hover{color:var(--text);background:rgba(255,255,255,0.05);}
.hnav-right{margin-left:auto;display:flex;align-items:center;gap:12px;}
.btn-nav{background:var(--accent);color:white;border:none;padding:9px 20px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;}
.btn-nav:hover{opacity:0.85;transform:translateY(-1px);}
.btn-nav-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);padding:9px 20px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;}
.btn-nav-ghost:hover{color:var(--text);}

.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(108,99,255,0.13) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 80%,rgba(0,212,170,0.06) 0%,transparent 60%);}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 80% 60% at 50% 50%,black,transparent);}
.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.25);border-radius:100px;padding:6px 16px;font-size:12px;font-weight:600;color:#a09aff;margin-bottom:32px;}
.badge-dot{width:6px;height:6px;background:var(--accent3);border-radius:50%;animation:pulse 2s infinite;}
.hero h1{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(42px,7vw,88px);line-height:1.0;letter-spacing:-3px;margin-bottom:22px;color:#f0f0f5;}
.hero h1 .grad{display:block;background:linear-gradient(135deg,var(--accent) 0%,var(--accent3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-sub{font-size:clamp(16px,2vw,19px);color:var(--muted);max-width:520px;line-height:1.65;margin-bottom:44px;}
.hero-actions{display:flex;gap:13px;align-items:center;justify-content:center;}
.btn-hero{background:var(--accent);color:white;border:none;padding:15px 32px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;cursor:pointer;box-shadow:0 0 32px rgba(108,99,255,0.3);transition:all 0.2s;}
.btn-hero:hover{transform:translateY(-2px);box-shadow:0 0 44px rgba(108,99,255,0.45);}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);padding:15px 32px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;cursor:pointer;transition:all 0.2s;}
.btn-ghost:hover{color:var(--text);}
.hero-note{margin-top:18px;font-size:13px;color:var(--muted);}

.stats-strip{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:26px 40px;display:flex;justify-content:center;gap:80px;background:var(--surface);}
.stat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;color:var(--text);}
.stat-lbl{font-size:13px;color:var(--muted);margin-top:2px;text-align:center;}

.home-section{padding:90px 40px;max-width:1100px;margin:0 auto;}
.sec-label{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent);margin-bottom:14px;}
.sec-title{font-family:'Syne',sans-serif;font-weight:700;font-size:clamp(28px,4vw,44px);letter-spacing:-1.5px;margin-bottom:12px;line-height:1.1;}
.sec-sub{color:var(--muted);font-size:16px;margin-bottom:48px;max-width:480px;line-height:1.6;}

.pillars-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
.pillar{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:30px;transition:all 0.25s;position:relative;overflow:hidden;}
.pillar::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--pc);opacity:0;transition:opacity 0.3s;}
.pillar:hover{transform:translateY(-3px);border-color:rgba(255,255,255,0.12);}
.pillar:hover::before{opacity:1;}
.pillar.live{cursor:pointer;}
.p1{--pc:var(--accent);}
.p2{--pc:var(--accent3);}
.p3{--pc:var(--accent2);}
.p4{--pc:var(--yellow);}
.pillar-icon{font-size:26px;margin-bottom:14px;}
.pillar-tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--pc);margin-bottom:7px;}
.pillar-title{font-family:'Syne',sans-serif;font-weight:700;font-size:19px;margin-bottom:8px;}
.pillar-desc{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;}
.pillar-meta{font-size:12px;color:var(--muted);}
.pillar-meta span{color:var(--pc);font-weight:600;}

.how-strip{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:90px 40px;}
.how-inner{max-width:1100px;margin:0 auto;}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:48px;margin-top:48px;}
.step-num{font-family:'Syne',sans-serif;font-weight:800;font-size:52px;color:rgba(108,99,255,0.08);line-height:1;margin-bottom:12px;}
.step-title{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;margin-bottom:8px;}
.step-desc{font-size:14px;color:var(--muted);line-height:1.7;}

.tiktok-strip{padding:90px 40px;max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;}
.tv-box{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:26px;position:relative;overflow:hidden;}
.tv-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent3));}
.tv-lbl{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent3);margin-bottom:16px;}
.tv-row{display:flex;align-items:flex-start;gap:10px;padding:11px;background:var(--bg);border-radius:9px;margin-bottom:9px;border:1px solid var(--border);}
.tv-icon{font-size:17px;flex-shrink:0;margin-top:2px;}
.tv-text{font-size:13px;color:var(--muted);line-height:1.5;}
.tv-text strong{color:var(--text);font-weight:500;}

.tracks-strip{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:90px 40px;}
.tracks-inner{max-width:1100px;margin:0 auto;}
.tracks-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:48px;}
.track{background:var(--bg);border:1px solid var(--border);border-radius:13px;padding:26px;transition:border-color 0.2s;}
.track:hover{border-color:rgba(108,99,255,0.25);}
.track-age{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:var(--accent);margin-bottom:4px;}
.track-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:8px;}
.track-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
.track-badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);border-radius:100px;padding:3px 10px;color:#a09aff;}
.track-badge.live{background:rgba(0,212,170,0.1);border-color:rgba(0,212,170,0.2);color:var(--accent3);}

.parents-strip-section{padding:90px 40px;max-width:1100px;margin:0 auto;}
.parents-box{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:48px;position:relative;overflow:hidden;}
.parents-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent3),var(--accent));}
.parents-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;}
.parents-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(24px,3vw,36px);letter-spacing:-1px;line-height:1.1;margin-bottom:14px;}
.parents-title .grad{background:linear-gradient(130deg,var(--accent3),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.parents-body{font-size:15px;color:var(--muted);line-height:1.8;}
.parents-body strong{color:var(--text);font-weight:500;}
.ppoints{display:flex;flex-direction:column;gap:12px;}
.ppoint{display:flex;gap:13px;align-items:flex-start;background:var(--bg);border:1px solid var(--border);border-radius:11px;padding:14px 16px;}
.ppoint-icon{font-size:18px;flex-shrink:0;}
.ppoint-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:3px;}
.ppoint-text{font-size:12px;color:var(--muted);line-height:1.5;}

.cta-section{padding:90px 40px;text-align:center;}
.cta-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(32px,5vw,56px);letter-spacing:-2px;line-height:1.05;margin-bottom:18px;}
.cta-sub{font-size:17px;color:var(--muted);line-height:1.6;margin-bottom:38px;}

site-footer{display:block;border-top:1px solid var(--border);padding:28px 40px;display:flex;align-items:center;justify-content:space-between;}
.footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:15px;cursor:pointer;}
.footer-logo span{color:var(--accent);}
.footer-copy{font-size:13px;color:var(--muted);}

/* ══════════════════════════════════════
   PAGE 2: LOGIN
══════════════════════════════════════ */
.login-bg{position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse 55% 50% at 20% 30%,rgba(108,99,255,0.07) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 70%,rgba(0,212,170,0.05) 0%,transparent 60%);}
.login-grid{position:fixed;inset:0;pointer-events:none;z-index:0;background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);background-size:52px 52px;mask-image:radial-gradient(ellipse 70% 70% at 30% 40%,black,transparent);}
.login-nav{position:relative;z-index:10;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--border);background:rgba(10,10,15,0.92);backdrop-filter:blur(20px);}
.login-back{margin-left:auto;font-size:13px;color:var(--muted);cursor:pointer;display:flex;align-items:center;gap:6px;transition:color 0.2s;}
.login-back:hover{color:var(--text);}
.login-body{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 24px;position:relative;z-index:1;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:20px;width:100%;max-width:420px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.4);}
.card-top{padding:30px 30px 0;position:relative;}
.card-top::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent3));}
.mode-toggle{display:flex;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:3px;margin-bottom:26px;}
.mode-btn{flex:1;padding:8px;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;color:var(--muted);cursor:pointer;border-radius:7px;transition:all 0.2s;}
.mode-btn.active{background:var(--surface2);color:var(--text);}
.card-title{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;letter-spacing:-0.5px;margin-bottom:5px;}
.card-sub{font-size:13px;color:var(--muted);margin-bottom:26px;line-height:1.5;}
.card-body{padding:0 30px 26px;}
.social-btns{display:flex;flex-direction:column;gap:9px;margin-bottom:18px;}
.social-btn{width:100%;display:flex;align-items:center;gap:12px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 15px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;color:var(--text);cursor:pointer;transition:all 0.2s;}
.social-btn:hover{border-color:rgba(255,255,255,0.15);background:var(--surface2);transform:translateY(-1px);}
.sb-icon{width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:15px;}
.sb-arrow{color:var(--muted);font-size:12px;margin-left:auto;}
.divider{display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.divider-line{flex:1;height:1px;background:var(--border);}
.divider-text{font-size:12px;color:var(--muted);white-space:nowrap;}
.email-form{display:flex;flex-direction:column;gap:10px;margin-bottom:18px;}
.field{display:flex;flex-direction:column;gap:5px;}
.field label{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:0.5px;}
.field input{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:11px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;transition:border-color 0.2s;}
.field input:focus{border-color:rgba(108,99,255,0.5);}
.field input::placeholder{color:var(--muted);}
.btn-submit{width:100%;background:var(--accent);color:white;border:none;padding:13px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;box-shadow:0 0 20px rgba(108,99,255,0.25);transition:all 0.2s;margin-top:4px;}
.btn-submit:hover{opacity:0.88;transform:translateY(-1px);}
.terms-txt{font-size:11px;color:var(--muted);text-align:center;line-height:1.6;margin-bottom:14px;}
.terms-txt a{color:var(--accent);text-decoration:none;}
.switch-ln{font-size:13px;color:var(--muted);text-align:center;margin-bottom:6px;}
.switch-ln a{color:var(--accent);cursor:pointer;font-weight:500;}
.guest-ln{text-align:center;padding-bottom:2px;}
.guest-ln a{font-size:12px;color:var(--muted);cursor:pointer;transition:color 0.2s;}
.guest-ln a:hover{color:var(--text);}
.parent-banner{border-top:1px solid var(--border);padding:15px 28px;display:flex;align-items:center;gap:12px;background:rgba(0,212,170,0.03);cursor:pointer;transition:background 0.2s;}
.parent-banner:hover{background:rgba(0,212,170,0.06);}
.pb-text{flex:1;}
.pb-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px;}
.pb-sub{font-size:11px;color:var(--muted);}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(8px);z-index:200;display:none;align-items:center;justify-content:center;padding:24px;pointer-events:none;}
.modal-overlay.open{display:flex;pointer-events:all;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:20px;width:100%;max-width:420px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.6);animation:slideUp 0.3s ease both;}
.modal-hd{padding:22px 26px 0;position:relative;}
.modal-hd::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent3),var(--accent));}
.modal-close{position:absolute;top:14px;right:18px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;width:26px;height:26px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);cursor:pointer;transition:all 0.2s;}
.modal-close:hover{color:var(--text);}
.modal-tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent3);margin-bottom:8px;}
.modal-title{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;letter-spacing:-0.5px;margin-bottom:5px;}
.modal-sub{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.5;}
.modal-bd{padding:0 26px 26px;}
.modal-note{background:rgba(0,212,170,0.05);border:1px solid rgba(0,212,170,0.15);border-radius:10px;padding:11px 13px;font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:18px;}
.modal-note strong{color:var(--text);font-weight:500;}

/* ══════════════════════════════════════
   PAGE 3: COURSE OVERVIEW
══════════════════════════════════════ */
.course-layout{display:flex;flex:1;overflow:hidden;height:calc(100vh - 52px);}
.dot-rail{width:62px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:28px 0;flex-shrink:0;position:relative;z-index:50;overflow:visible;}
.rail-lbl{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:18px;writing-mode:vertical-rl;text-orientation:mixed;transform:rotate(180deg);opacity:0.4;}
.rail-inner{display:flex;flex-direction:column;align-items:center;position:relative;padding-bottom:0;}
/* Continuous vertical line behind dots */
.rail-inner::before{content:'';position:absolute;top:5px;left:50%;transform:translateX(-50%);width:2px;height:calc(100% - 10px);background:rgba(255,255,255,0.05);z-index:0;}
.rail-progress-line{position:absolute;top:0;left:50%;transform:translateX(-50%);width:2px;height:0%;background:linear-gradient(to bottom,var(--accent3),var(--accent));z-index:1;transition:height 0.4s ease;}
.rnode{display:flex;flex-direction:column;align-items:center;cursor:pointer;position:relative;}
.rnode:hover .rtip{opacity:1;}
.rdot{width:11px;height:11px;border-radius:50%;border:2px solid rgba(255,255,255,0.12);background:transparent;transition:all 0.3s;position:relative;z-index:2;flex-shrink:0;}
.rdot.done{border-color:var(--accent3);background:var(--accent3);box-shadow:0 0 8px rgba(0,212,170,0.4);}
.rdot.active{border-color:var(--accent);background:var(--accent);box-shadow:0 0 14px rgba(108,99,255,0.7);transform:scale(1.45);}
.rnode:hover .rdot:not(.active):not(.done){border-color:rgba(255,255,255,0.4);transform:scale(1.2);}
.rconn{width:2px;height:44px;background:rgba(255,255,255,0.06);position:relative;}
.rconn::after{content:'';position:absolute;top:0;left:0;width:100%;height:0%;background:linear-gradient(to bottom,var(--accent3),rgba(0,212,170,0.2));transition:height 0.5s ease;}
.rconn.done::after{height:100%;}
.rconn.active::after{height:50%;background:linear-gradient(to bottom,var(--accent),transparent);}
.rtip{position:fixed;left:72px;top:50%;transform:translateY(-50%);background:var(--surface2);border:1px solid rgba(255,255,255,0.18);border-radius:8px;padding:7px 13px;font-size:11px;font-weight:500;color:var(--text);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:99999;box-shadow:0 4px 24px rgba(0,0,0,0.7);}
.course-content{flex:1;overflow-y:auto;padding-bottom:120px;}
.course-content::-webkit-scrollbar{width:3px;}
.course-content::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.05);}
.cslide{min-height:calc(100vh - 52px);padding:52px 60px;display:flex;flex-direction:column;justify-content:center;border-bottom:1px solid var(--border);position:relative;overflow:hidden;opacity:0;transform:translateY(16px);transition:opacity 0.5s ease,transform 0.5s ease;}
.cslide.visible{opacity:1;transform:translateY(0);}
.cslide-inner{max-width:560px;}
.cs1{background:var(--bg);}
.cs1::before{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 65% 55% at 50% 40%,rgba(108,99,255,0.08) 0%,transparent 70%);}
.cs1::after{content:'';position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.018) 1px,transparent 1px);background-size:44px 44px;mask-image:radial-gradient(ellipse 80% 70% at 50% 40%,black,transparent);}
.cs2{background:var(--surface);}
.cs3{background:var(--bg);}
.mod-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.22);border-radius:100px;padding:5px 14px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#a09aff;margin-bottom:26px;width:fit-content;}
.tag-dot{width:6px;height:6px;background:var(--accent3);border-radius:50%;animation:pulse 2s infinite;}
.big-h{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(34px,5vw,62px);line-height:1.0;letter-spacing:-2px;margin-bottom:18px;}
.big-h .grad{background:linear-gradient(130deg,var(--accent) 0%,var(--accent3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.med-h{font-family:'Syne',sans-serif;font-weight:700;font-size:clamp(22px,3vw,36px);letter-spacing:-1px;line-height:1.1;margin-bottom:12px;}
.s-label{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
.hcards{display:flex;gap:12px;margin-bottom:40px;}
.hcard{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:18px 20px;flex:1;position:relative;overflow:hidden;transition:all 0.2s;}
.hcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.hc1::before{background:var(--accent);}
.hc2::before{background:var(--accent3);}
.hc3::before{background:var(--accent2);}
.hcard:hover{transform:translateY(-2px);}
.hcard-num{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;line-height:1;margin-bottom:4px;}
.hc1 .hcard-num{color:var(--accent);}
.hc2 .hcard-num{color:var(--accent3);}
.hc3 .hcard-num{color:var(--accent2);}
.hcard-lbl{font-size:12px;color:var(--muted);}
.scroll-cue{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--muted);}
.arrow-c{width:28px;height:28px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;animation:bob 2s ease-in-out infinite;}
.mod-list{display:flex;flex-direction:column;gap:8px;}
.mrow{display:flex;align-items:center;gap:14px;background:var(--bg);border:1px solid var(--border);border-radius:11px;padding:13px 16px;transition:all 0.2s;}
.mrow.done{border-color:rgba(0,212,170,0.2);}
.mrow.cur{border-color:rgba(108,99,255,0.35);background:rgba(108,99,255,0.04);cursor:pointer;}
.mrow.locked{opacity:0.4;}
.mrow.cur:hover{border-color:rgba(108,99,255,0.5);}
.mrow.done:hover{cursor:pointer;border-color:rgba(0,212,170,0.35);}
.mnum{font-family:'Syne',sans-serif;font-weight:800;font-size:12px;color:var(--muted);min-width:22px;flex-shrink:0;}
.mrow.done .mnum{color:var(--accent3);}
.mrow.cur .mnum{color:var(--accent);}
.minfo{flex:1;}
.mtitle{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:2px;}
.mdesc{font-size:12px;color:var(--muted);line-height:1.4;}
.mbadge{font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px;white-space:nowrap;flex-shrink:0;}
.done-b{background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
.cur-b{background:rgba(108,99,255,0.12);border:1px solid rgba(108,99,255,0.25);color:#a09aff;}
.lock-b{color:var(--muted);}
.cta-card{background:var(--surface);border:1px solid rgba(108,99,255,0.25);border-radius:13px;padding:22px 24px;display:flex;align-items:center;justify-content:space-between;max-width:560px;margin-bottom:24px;position:relative;overflow:hidden;}
.cta-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent3));}
.cta-mnum{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:3px;}
.cta-mtitle{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;margin-bottom:5px;}
.cta-mdesc{font-size:13px;color:var(--muted);line-height:1.5;max-width:280px;}
.cta-btn{background:var(--accent);color:white;border:none;padding:12px 22px;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all 0.2s;}
.cta-btn:hover{transform:translateY(-2px);}
.prog-row{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:7px;}
.prog-bar{height:5px;background:var(--surface2);border-radius:3px;overflow:hidden;max-width:560px;}
.prog-fill{height:100%;width:22%;background:linear-gradient(90deg,var(--accent),var(--accent3));border-radius:3px;}

/* ══════════════════════════════════════
   PAGE 4: MODULE — with notebook
══════════════════════════════════════ */
.mod-layout{display:flex;flex:1;overflow:hidden;min-height:0;}
.mod-content{flex:1;overflow-y:auto;scroll-behavior:smooth;padding-bottom:120px;}
.mod-content::-webkit-scrollbar{width:3px;}
.mod-content::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.05);}
/* Rail stays full height, content scrolls independently */
.mod-layout > .dot-rail{overflow-y:auto;align-self:stretch;flex-shrink:0;}
.mod-layout > .dot-rail::-webkit-scrollbar{display:none;}
.mslide{min-height:100vh;padding:52px 52px;display:flex;flex-direction:column;justify-content:center;border-bottom:1px solid var(--border);position:relative;overflow:hidden;opacity:0;transform:translateY(16px);transition:opacity 0.5s ease,transform 0.5s ease;}
.mslide.visible{opacity:1;transform:translateY(0);}
.mslide-inner{max-width:520px;}
.ms-hook{background:var(--bg);}
.ms-hook::before{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 65% 55% at 50% 40%,rgba(108,99,255,0.09) 0%,transparent 70%);}
.ms-hook::after{content:'';position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.018) 1px,transparent 1px);background-size:44px 44px;mask-image:radial-gradient(ellipse 80% 70% at 50% 40%,black,transparent);}
.ms-text{background:var(--surface);}
.ms-ex{background:var(--bg);}
.ms-sand{background:var(--surface);}
.ms-quiz{background:var(--bg);}
.ms-done{background:var(--bg);}
.ms-done::before{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(0,212,170,0.07) 0%,transparent 70%);}
.sec-meta{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.sec-num{font-family:'Syne',sans-serif;font-weight:800;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);}
.sec-min{font-size:11px;color:var(--muted);}
.sec-div{width:1px;height:10px;background:var(--border);}
.infographic{margin:20px 0;border-radius:14px;overflow:hidden;border:1px solid var(--border);}
.meta-row{display:flex;gap:11px;margin-bottom:32px;flex-wrap:wrap;}
.meta-chip{display:flex;align-items:center;gap:5px;background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:12px;font-weight:500;color:var(--muted);}
.scards{display:flex;gap:11px;margin-bottom:34px;}
.scard{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 18px;flex:1;position:relative;overflow:hidden;transition:all 0.2s;}
.scard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.sc1::before{background:var(--accent);}
.sc2::before{background:var(--accent3);}
.sc3::before{background:var(--accent2);}
.scard-n{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;line-height:1;margin-bottom:3px;}
.sc1 .scard-n{color:var(--accent);}
.sc2 .scard-n{color:var(--accent3);}
.sc3 .scard-n{color:var(--accent2);}
.scard-l{font-size:12px;color:var(--muted);}
.concept{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:18px 20px;margin-bottom:12px;}
.concept-lbl{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:7px;}
.concept-txt{font-size:14px;color:var(--text);line-height:1.7;}
.concept-txt em{color:var(--accent3);font-style:normal;font-weight:600;}
.callout{background:rgba(108,99,255,0.06);border:1px solid rgba(108,99,255,0.2);border-left:3px solid var(--accent);border-radius:0 10px 10px 0;padding:14px 18px;margin-bottom:20px;}
.callout-t{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:5px;}
.callout-b{font-size:14px;color:var(--muted);line-height:1.6;}
.callout-b strong{color:var(--text);font-weight:500;}
.callout.green{background:rgba(0,212,170,0.05);border-color:rgba(0,212,170,0.2);border-left-color:var(--accent3);}
.callout.green .callout-t{color:var(--accent3);}
.cmp-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-bottom:18px;}
.cmp-card{background:var(--surface2);border:1px solid var(--border);border-radius:11px;padding:16px;}
.cmp-card.bad{border-top:2px solid var(--accent2);}
.cmp-card.good{border-top:2px solid var(--accent3);}
.cmp-lbl{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;}
.cmp-card.bad .cmp-lbl{color:var(--accent2);}
.cmp-card.good .cmp-lbl{color:var(--accent3);}
.cmp-p{font-size:13px;color:var(--text);font-style:italic;line-height:1.55;padding:9px 11px;background:var(--bg);border-radius:6px;border:1px solid var(--border);margin-bottom:9px;}
.cmp-r{font-size:12px;color:var(--muted);line-height:1.5;}
.formula-box{background:var(--bg);border:1px solid var(--border);border-radius:13px;padding:22px;margin-bottom:18px;position:relative;overflow:hidden;}
.formula-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent3));}
.f-lbl{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
.fparts{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:14px;}
.fp{padding:7px 13px;border-radius:7px;font-size:12px;font-weight:600;}
.fp.role{background:rgba(108,99,255,0.15);color:#a09aff;border:1px solid rgba(108,99,255,0.2);}
.fp.task{background:rgba(0,212,170,0.12);color:var(--accent3);border:1px solid rgba(0,212,170,0.2);}
.fp.ctx{background:rgba(255,107,107,0.1);color:var(--accent2);border:1px solid rgba(255,107,107,0.2);}
.fp.fmt{background:rgba(247,201,72,0.1);color:var(--yellow);border:1px solid rgba(247,201,72,0.2);}
.fp.plus{color:var(--muted);font-size:15px;font-weight:300;padding:0 2px;}
.fex{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:13px;font-size:13px;line-height:1.7;}
.fex .rt{color:#a09aff;font-weight:600;}
.fex .tt{color:var(--accent3);font-weight:600;}
.fex .ct{color:var(--accent2);font-weight:600;}
.fex .ft{color:var(--yellow);font-weight:600;}
.sandbox{background:var(--bg);border:1px solid var(--border);border-radius:13px;overflow:hidden;margin-bottom:12px;}
.sb-hd{display:flex;align-items:center;gap:7px;padding:11px 15px;border-bottom:1px solid var(--border);background:var(--surface);}
.wdot{width:9px;height:9px;border-radius:50%;}
.wdot.r{background:#ff5f57;}.wdot.y{background:#febc2e;}.wdot.g{background:#28c840;}
.sb-ttl{font-size:12px;color:var(--muted);margin-left:4px;font-weight:500;}
.sb-live{margin-left:auto;background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.2);border-radius:100px;padding:3px 9px;font-size:10px;font-weight:600;color:var(--accent3);letter-spacing:1px;text-transform:uppercase;}
.sb-body{padding:16px;display:flex;flex-direction:column;gap:11px;min-height:160px;max-height:220px;overflow-y:auto;}
.sb-body::-webkit-scrollbar{width:2px;}
.msg{display:flex;gap:8px;align-items:flex-start;animation:fadeUp 0.3s ease both;}
.msg-r{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 7px;border-radius:4px;white-space:nowrap;margin-top:2px;flex-shrink:0;}
.msg-r.you{background:rgba(108,99,255,0.15);color:#a09aff;}
.msg-r.ai{background:rgba(0,212,170,0.1);color:var(--accent3);}
.msg-t{font-size:13px;color:var(--text);line-height:1.6;}
.msg-t.dim{color:var(--muted);}
.cblink{display:inline-block;width:2px;height:13px;background:var(--accent3);margin-left:2px;vertical-align:middle;animation:blink 1s infinite;}
.sb-inp-row{display:flex;border-top:1px solid var(--border);}
.sb-inp{flex:1;background:transparent;border:none;outline:none;padding:12px 15px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);}
.sb-inp::placeholder{color:var(--muted);}
.sb-send{background:var(--accent);border:none;padding:0 18px;color:white;font-size:14px;cursor:pointer;transition:opacity 0.2s;}
.sb-send:hover{opacity:0.8;}
.sb-hint{font-size:12px;color:var(--muted);line-height:1.5;}
.sandbox-box{background:var(--bg);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.sandbox-messages{display:flex;flex-direction:column;gap:10px;padding:14px;min-height:80px;}
.sb-msg{font-size:13px;line-height:1.6;padding:8px 12px;border-radius:8px;max-width:88%;}
.sb-msg.user{background:rgba(108,99,255,0.12);border:1px solid rgba(108,99,255,0.2);color:var(--text);align-self:flex-end;}
.sb-msg.ai{background:var(--surface);border:1px solid var(--border);color:var(--muted);align-self:flex-start;}
.sandbox-input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:8px;outline:none;padding:10px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);transition:border-color 0.2s;}
.sandbox-input::placeholder{color:var(--muted);}
.sandbox-input:focus{border-color:rgba(108,99,255,0.4);}
.sandbox-send{background:var(--accent);border:none;border-radius:8px;padding:0 16px;color:white;font-size:14px;cursor:pointer;transition:opacity 0.2s;min-width:40px;height:40px;flex-shrink:0;}
.sandbox-send:hover{opacity:0.8;}
/* Per-section mini quizzes */
.sq{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;margin:20px 0;}
.sq-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--yellow);margin-bottom:10px;}
.sq-q{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:14px;line-height:1.4;}
.sq-opts{display:flex;flex-direction:column;gap:7px;}
.sqopt{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 13px;font-size:13px;color:var(--text);cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:9px;}
.sqopt:hover{border-color:rgba(108,99,255,0.4);}
.sqopt.correct{border-color:var(--accent3);background:rgba(0,212,170,0.06);}
.sqopt.wrong{border-color:var(--accent2);background:rgba(255,107,107,0.05);}
.sq-ltr{width:22px;height:22px;border-radius:5px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--muted);flex-shrink:0;transition:all 0.2s;}
.sqopt.correct .sq-ltr{background:var(--accent3);color:white;}
.sqopt.wrong .sq-ltr{background:var(--accent2);color:white;}
.sq-result{margin-top:11px;padding:10px 13px;border-radius:8px;font-size:12px;line-height:1.5;display:none;}
.sq-result.show{display:block;}
.sq-result.win{background:rgba(0,212,170,0.07);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
.sq-result.lose{background:rgba(255,107,107,0.06);border:1px solid rgba(255,107,107,0.15);color:var(--accent2);}
/* Final quiz */
.quiz-box{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:24px;margin-bottom:18px;}
.quiz-q{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;margin-bottom:18px;line-height:1.4;}
.quiz-opts{display:flex;flex-direction:column;gap:8px;}
.qopt{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:11px 14px;font-size:13px;color:var(--text);cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:10px;}
.qopt:hover{border-color:rgba(108,99,255,0.35);}
.qopt.correct{border-color:var(--accent3);background:rgba(0,212,170,0.06);}
.qopt.wrong{border-color:var(--accent2);background:rgba(255,107,107,0.05);}
.qltr{width:23px;height:23px;border-radius:5px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--muted);flex-shrink:0;transition:all 0.2s;}
.qopt.correct .qltr{background:var(--accent3);color:white;}
.qopt.wrong .qltr{background:var(--accent2);color:white;}
.qresult{margin-top:14px;padding:12px 15px;border-radius:9px;font-size:13px;line-height:1.6;display:none;}
.qresult.show{display:block;}
.qresult.win{background:rgba(0,212,170,0.07);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
.qresult.lose{background:rgba(255,107,107,0.06);border:1px solid rgba(255,107,107,0.15);color:var(--accent2);}
/* Complete */
.confetti-zone{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;}
.confetti-piece{position:absolute;width:8px;height:8px;border-radius:2px;animation:fall linear forwards;}
@keyframes fall{0%{transform:translateY(-20px) rotate(0deg);opacity:1;}100%{transform:translateY(110vh) rotate(720deg);opacity:0;}}
.complete-icon{font-size:48px;margin-bottom:18px;}
.done-actions{display:flex;gap:11px;margin-top:28px;flex-wrap:wrap;}
.btn-primary{background:var(--accent);color:white;border:none;padding:13px 24px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 0 20px rgba(108,99,255,0.25);transition:all 0.2s;}
.btn-primary:hover{transform:translateY(-2px);}
.btn-secondary{background:transparent;color:var(--muted);border:1px solid var(--border);padding:13px 24px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;}
.btn-secondary:hover{color:var(--text);border-color:rgba(255,255,255,0.15);}
.xp-earned{display:inline-flex;align-items:center;gap:8px;background:rgba(247,201,72,0.1);border:1px solid rgba(247,201,72,0.2);border-radius:10px;padding:11px 16px;margin-bottom:6px;}
.xp-n{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:var(--yellow);}
.xp-l{font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:1px;}
.letsgo-btn{display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:white;border:none;padding:12px 24px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;box-shadow:0 0 24px rgba(108,99,255,0.3);transition:all 0.2s;margin-top:8px;}
.letsgo-btn:hover{transform:translateY(-2px);}
/* Notebook */
.nb-fab{position:fixed;bottom:28px;right:28px;z-index:600;display:none;background:var(--surface);border:1px solid rgba(255,255,255,0.1);border-radius:100px;padding:10px 18px;align-items:center;gap:8px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:var(--text);cursor:pointer;box-shadow:0 8px 32px rgba(0,0,0,0.4);transition:all 0.2s;}
.nb-fab:hover{border-color:rgba(108,99,255,0.5);transform:translateY(-2px);}
body.nb-visible .nb-fab{display:flex;}
.nb-fab-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);flex-shrink:0;animation:pulse 2s infinite;}
.nb-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(8px);z-index:700;opacity:0;pointer-events:none;transition:opacity 0.2s;}
.nb-overlay.open{opacity:1;pointer-events:all;}
.nb-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-48%) scale(0.97);opacity:0;pointer-events:none;width:min(900px,92vw);height:min(660px,88vh);background:var(--bg);border:1px solid rgba(255,255,255,0.07);border-radius:22px;display:flex;flex-direction:column;z-index:800;box-shadow:0 40px 100px rgba(0,0,0,0.6);transition:transform 0.28s cubic-bezier(0.34,1.3,0.64,1),opacity 0.2s;overflow:hidden;}
.nb-modal.open{transform:translate(-50%,-50%) scale(1);opacity:1;pointer-events:all;}
.nb-modal-top{display:flex;align-items:center;padding:20px 24px 0;gap:14px;flex-shrink:0;}
.nb-modal-title{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;flex:1;}
.nb-modal-sub{font-size:12px;color:var(--muted);}
.nb-close{width:30px;height:30px;background:rgba(255,255,255,0.06);border:none;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;color:var(--muted);transition:all 0.15s;flex-shrink:0;}
.nb-close:hover{background:rgba(255,255,255,0.12);color:var(--text);}
.nb-tabs{display:flex;align-items:center;gap:3px;padding:14px 24px 0;overflow-x:auto;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,0.06);padding-bottom:0;min-height:0;}
.nb-tabs::-webkit-scrollbar{display:none;}
.nb-tab{padding:9px 16px;border-radius:10px 10px 0 0;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;white-space:nowrap;border:1px solid transparent;border-bottom:none;transition:all 0.15s;position:relative;top:1px;}
.nb-tab:hover{color:var(--text);}
.nb-tab.active{background:var(--surface);border-color:rgba(255,255,255,0.07);color:var(--text);}

.nb-tab-editing{padding:4px 8px !important;}
.nb-tab-input{background:transparent;border:none;border-bottom:1px solid rgba(108,99,255,0.5);outline:none;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;color:var(--text);width:90px;padding:2px 0;}
.profile-pill{display:flex;align-items:center;gap:5px;border-radius:8px;padding:5px 12px;font-size:12px;font-weight:600;background:transparent;border:none;color:var(--muted);cursor:pointer;transition:all 0.2s;}
.profile-pill:hover{color:var(--text);background:rgba(255,255,255,0.05);}
.nb-tab-add{padding:7px 13px;border-radius:8px;font-size:12px;font-weight:600;color:var(--accent);cursor:pointer;border:1px dashed rgba(108,99,255,0.3);margin-left:4px;margin-bottom:1px;transition:all 0.15s;}
.nb-tab-add:hover{background:rgba(108,99,255,0.08);border-color:rgba(108,99,255,0.5);}
.nb-body{flex:1;overflow-y:auto;padding:24px;display:none;flex-direction:column;gap:18px;-webkit-overflow-scrolling:touch;}
.nb-body.active{display:flex;}
.nb-body::-webkit-scrollbar{width:3px;}
.nb-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.07);}
.nb-q-card{background:var(--surface);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;display:flex;flex-direction:column;gap:12px;}
.nb-q-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:2px;}
.nb-q-row{display:flex;flex-direction:column;gap:6px;}
.nb-q-text{font-size:13px;color:var(--muted);line-height:1.55;}
.nb-input{background:var(--bg);border:1px solid rgba(255,255,255,0.07);border-radius:9px;padding:10px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);width:100%;resize:vertical;min-height:72px;outline:none;line-height:1.65;transition:border-color 0.2s;}
.nb-input:focus{border-color:rgba(108,99,255,0.4);}
.nb-input::placeholder{color:rgba(122,122,154,0.6);}
.nb-free-card{background:var(--surface);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;flex:1;display:flex;flex-direction:column;gap:8px;min-height:200px;}
.nb-card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;}
.nb-card-sub{font-size:12px;color:var(--muted);}
.nb-free-input{background:var(--bg);border:1px solid rgba(255,255,255,0.07);border-radius:9px;padding:12px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);flex:1;resize:none;outline:none;line-height:1.7;min-height:160px;transition:border-color 0.2s;}
.nb-free-input:focus{border-color:rgba(108,99,255,0.3);}
.nb-free-input::placeholder{color:rgba(122,122,154,0.5);}

/* SHARED */
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(1.4);}}
@keyframes bob{0%,100%{transform:translateY(0);}50%{transform:translateY(5px);}}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.fade-in{opacity:0;transform:translateY(18px);transition:opacity 0.6s ease,transform 0.6s ease;}
.fade-in.visible{opacity:1;transform:translateY(0);}

/* ── ACTIVE RECALL BOX ── */
.recall{background:rgba(108,99,255,0.05);border:1px solid rgba(108,99,255,0.2);border-radius:12px;padding:18px 20px;margin:20px 0;}
.recall-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;}
.recall-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.recall-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:4px;}
.recall-q{font-size:14px;color:var(--text);line-height:1.55;font-weight:500;}
.recall-area{width:100%;min-height:72px;background:var(--bg);border:1px solid rgba(108,99,255,0.2);border-radius:8px;padding:10px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;resize:none;line-height:1.6;transition:border-color 0.2s;box-sizing:border-box;}
.recall-area:focus{border-color:rgba(108,99,255,0.5);}
.recall-area::placeholder{color:var(--muted);font-style:italic;}
.recall-hint{font-size:11px;color:var(--muted);margin-top:7px;display:flex;align-items:center;gap:5px;}

/* ── COMPACT PILLARS ── */
.pillars-compact{display:flex;flex-direction:column;gap:8px;max-width:680px;}
.pc{display:flex;align-items:center;justify-content:space-between;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;transition:all 0.2s;position:relative;overflow:hidden;}
.pc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--pc);opacity:0;transition:opacity 0.2s;}
.pc.live{cursor:pointer;}
.pc.live:hover{border-color:rgba(255,255,255,0.12);transform:translateX(3px);}
.pc.live:hover::before{opacity:1;}
.p1{--pc:var(--accent);}
.p2{--pc:var(--accent3);}
.p3{--pc:var(--accent2);}
.p4{--pc:var(--yellow);}
.pc-left{display:flex;align-items:center;gap:12px;}
.pc-icon{font-size:20px;flex-shrink:0;}
.pc-tag{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--pc);margin-bottom:2px;}
.pc-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text);}
.pc-right{display:flex;align-items:center;gap:12px;}
.pc-meta{font-size:12px;color:var(--muted);}
.pc-meta span{color:var(--pc);font-weight:600;}
.pc-arr{color:var(--muted);font-size:16px;transition:transform 0.2s;}
.pc.live:hover .pc-arr{transform:translateX(3px);color:var(--text);}

/* ══════════════════════════════════════
   PAGE 5: PROFILE
══════════════════════════════════════ */
.profile-layout{max-width:900px;margin:0 auto;padding:48px 40px;}
.profile-greeting{margin-bottom:40px;}
.profile-greeting-sub{font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:8px;}
.profile-greeting-name{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(32px,5vw,52px);letter-spacing:-1.5px;line-height:1.1;margin-bottom:10px;}
.profile-greeting-name .grad{background:linear-gradient(130deg,var(--accent),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.profile-greeting-msg{font-size:15px;color:var(--muted);line-height:1.6;max-width:520px;}
.profile-stats{display:flex;gap:12px;margin-bottom:40px;flex-wrap:wrap;}
.pstat{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 20px;flex:1;min-width:110px;position:relative;overflow:hidden;}
.pstat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.pstat.ps1::before{background:var(--yellow);}
.pstat.ps2::before{background:var(--accent2);}
.pstat.ps3::before{background:var(--accent);}
.pstat.ps4::before{background:var(--accent3);}
.pstat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;line-height:1;margin-bottom:4px;}
.pstat.ps1 .pstat-num{color:var(--yellow);}
.pstat.ps2 .pstat-num{color:var(--accent2);}
.pstat.ps3 .pstat-num{color:var(--accent);}
.pstat.ps4 .pstat-num{color:var(--accent3);}
.pstat-lbl{font-size:12px;color:var(--muted);}
.profile-section{margin-bottom:36px;}
.profile-section-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.profile-section-title{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;letter-spacing:-0.3px;}
.profile-section-link{font-size:12px;color:var(--accent);cursor:pointer;font-weight:600;transition:opacity 0.2s;}
.profile-section-link:hover{opacity:0.7;}
/* Course cards */
.pcourse-grid{display:flex;flex-direction:column;gap:10px;}
.pcourse{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:18px 20px;display:flex;align-items:center;gap:16px;transition:all 0.2s;cursor:pointer;position:relative;overflow:hidden;}
.pcourse::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--pc2);opacity:0;transition:opacity 0.2s;}
.pcourse:hover{border-color:rgba(255,255,255,0.12);transform:translateX(3px);}
.pcourse:hover::before{opacity:1;}
.pcourse-icon{font-size:22px;flex-shrink:0;}
.pcourse-info{flex:1;min-width:0;}
.pcourse-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:4px;}
.pcourse-meta{font-size:12px;color:var(--muted);}
.pcourse-prog{display:flex;align-items:center;gap:10px;margin-top:8px;}
.pcourse-bar{flex:1;height:4px;background:var(--surface2);border-radius:2px;overflow:hidden;}
.pcourse-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--pc2),rgba(108,99,255,0.4));}
.pcourse-pct{font-size:11px;color:var(--muted);font-weight:600;white-space:nowrap;}
.pcourse-btn{background:var(--accent);color:white;border:none;padding:8px 16px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all 0.2s;}
.pcourse-btn:hover{opacity:0.85;}
/* Project cards */
.pproject-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.pproject{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:20px;transition:all 0.2s;cursor:pointer;position:relative;overflow:hidden;}
.pproject::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--pp);}
.pproject:hover{border-color:rgba(255,255,255,0.12);transform:translateY(-2px);}
.pproject-tag{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--pp);margin-bottom:7px;}
.pproject-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:6px;}
.pproject-desc{font-size:12px;color:var(--muted);line-height:1.5;margin-bottom:12px;}
.pproject-status{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px;}
.pproject-status.wip{background:rgba(247,201,72,0.1);border:1px solid rgba(247,201,72,0.2);color:var(--yellow);}
.pproject-status.new{background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);color:#a09aff;}
.pproject-empty{background:var(--surface);border:1px dashed rgba(255,255,255,0.1);border-radius:13px;padding:28px 20px;text-align:center;color:var(--muted);font-size:13px;cursor:pointer;transition:all 0.2s;}
.pproject-empty:hover{border-color:rgba(108,99,255,0.3);color:var(--accent);}
.pproject-empty-icon{font-size:24px;margin-bottom:8px;}

/* ══════════════════════════════════════
   PAGE 6: PROJECTS
══════════════════════════════════════ */
.proj-page{max-width:1100px;margin:0 auto;padding:48px 40px;}
.proj-header{margin-bottom:40px;}
.proj-header-top{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:8px;}
.proj-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(28px,4vw,44px);letter-spacing:-1.5px;line-height:1.1;}
.proj-title .grad{background:linear-gradient(130deg,var(--yellow),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.proj-sub{font-size:15px;color:var(--muted);line-height:1.6;max-width:580px;}
.proj-filters{display:flex;gap:8px;margin-bottom:32px;flex-wrap:wrap;align-items:center;}
.pfilter{padding:6px 14px;border-radius:100px;font-size:12px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all 0.2s;font-family:'DM Sans',sans-serif;}
.pfilter:hover{color:var(--text);border-color:rgba(255,255,255,0.2);}
.pfilter.active{background:var(--accent);border-color:var(--accent);color:white;}
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.pcard{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:22px;transition:all 0.25s;cursor:pointer;position:relative;overflow:hidden;display:flex;flex-direction:column;}
.pcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--pc);opacity:0;transition:opacity 0.25s;}
.pcard:hover{transform:translateY(-3px);border-color:rgba(255,255,255,0.11);}
.pcard:hover::before{opacity:1;}
.pcard-age{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--pc);margin-bottom:8px;}
.pcard-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:7px;line-height:1.3;}
.pcard-desc{font-size:12px;color:var(--muted);line-height:1.55;flex:1;margin-bottom:14px;}
.pcard-tags{display:flex;gap:6px;flex-wrap:wrap;}
.ptag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:100px;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--muted);}
/* Create your own card */
.pcard-create{background:transparent;border:1px dashed rgba(108,99,255,0.3);border-radius:14px;padding:22px;cursor:pointer;transition:all 0.25s;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:180px;gap:10px;}
.pcard-create:hover{border-color:var(--accent);background:rgba(108,99,255,0.04);}
.pcard-create-icon{width:40px;height:40px;border-radius:10px;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);display:flex;align-items:center;justify-content:center;font-size:20px;}
.pcard-create-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--text);}
.pcard-create-sub{font-size:12px;color:var(--muted);line-height:1.5;}

.pdiff{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:3px 9px;border-radius:100px;margin-bottom:8px;}
.pdiff.guided{background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
.pdiff.balanced{background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);color:#a09aff;}
.pdiff.open{background:rgba(247,201,72,0.1);border:1px solid rgba(247,201,72,0.2);color:var(--yellow);}

/* ── PROJECTS PAGE THEME (yellow) ── */
#pg-projects {
  --accent: #e8a820;
  --accent-glow: rgba(232,168,32,0.15);
  --accent-soft: rgba(232,168,32,0.08);
  --accent-border: rgba(232,168,32,0.22);
  background: var(--bg);
  overflow-y: auto;
  height: 100vh;
}
#pg-projects .topnav {
  background: rgba(10,10,8,0.92);
  border-bottom: 1px solid rgba(232,168,32,0.12);
}
#pg-projects .logo span { color: #e8a820; }
#pg-projects .nav-sep { color: rgba(232,168,32,0.2); }
#pg-projects .crumb-dot { background: #e8a820; }
#pg-projects .pill.xp { background: rgba(232,168,32,0.1); border-color: rgba(232,168,32,0.2); color: #e8a820; }
#pg-projects .proj-page {
  background: var(--bg);
}
/* Yellow grid background */
#pg-projects .proj-page::before {
  content: '';
  position: fixed;
  inset: 52px 0 0 0;
  background:
    radial-gradient(ellipse 60% 40% at 50% 0%, rgba(232,168,32,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 30% 30% at 85% 80%, rgba(232,168,32,0.04) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}
#pg-projects .proj-header,
#pg-projects .proj-filters,
#pg-projects .proj-grid { position: relative; z-index: 1; }
/* Filter active state */
#pg-projects .pfilter.active {
  background: #e8a820;
  border-color: #e8a820;
  color: #0a0a0f;
}
#pg-projects .pfilter:hover {
  border-color: rgba(232,168,32,0.4);
  color: #e8a820;
}
/* Create card in yellow theme */
#pg-projects .pcard-create { border-color: rgba(232,168,32,0.25); }
#pg-projects .pcard-create:hover { border-color: #e8a820; background: rgba(232,168,32,0.04); }
#pg-projects .pcard-create-icon { background: rgba(232,168,32,0.1); border-color: rgba(232,168,32,0.2); }
/* Breadcrumb active */
#pg-projects .crumb.active { color: #e8a820; }

/* ══════════════════════════════════════
   PROJECT DETAIL PAGE
══════════════════════════════════════ */
#pg-proj-stock { --proj-accent: #e8a820; --proj-accent-soft: rgba(232,168,32,0.08); --proj-accent-border: rgba(232,168,32,0.2); }
#pg-proj-stock .topnav { background:rgba(10,10,8,0.92); border-bottom:1px solid rgba(232,168,32,0.12); }
#pg-proj-stock .logo span { color:var(--proj-accent); }
#pg-proj-stock .crumb-dot { background:var(--proj-accent); }



/* Tab bar */
.proj-tabs { display:flex; align-items:center; background:var(--surface); border-bottom:1px solid var(--border); padding:0 32px; flex-shrink:0; gap:0; overflow-x:auto; }
.proj-tabs::-webkit-scrollbar { display:none; }
.ptab { padding:0 20px; height:46px; display:flex; align-items:center; font-size:13px; font-weight:500; color:var(--muted); cursor:pointer; border-bottom:2px solid transparent; white-space:nowrap; transition:all 0.2s; }
.ptab:hover { color:var(--text); }
.ptab.active { color:var(--proj-accent,var(--accent)); border-bottom-color:var(--proj-accent,var(--accent)); font-weight:600; }
.proj-tab-content { flex:1; overflow:hidden; position:relative; }
.proj-panel { display:none; height:100%; overflow-y:auto; }
.proj-panel.active { display:block; }
.proj-panel::-webkit-scrollbar { width:3px; }
.proj-panel::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.05); }
.proj-inner { max-width:820px; margin:0 auto; padding:44px 40px; }

/* Overview */
.proj-ov-hero { margin-bottom:36px; }
.proj-ov-tag { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--proj-accent,var(--accent)); margin-bottom:12px; }
.proj-ov-title { font-family:'Syne',sans-serif; font-weight:800; font-size:clamp(26px,4vw,42px); letter-spacing:-1.2px; line-height:1.1; margin-bottom:14px; }
.proj-ov-desc { font-size:16px; color:var(--muted); line-height:1.8; margin-bottom:28px; }
.proj-ov-chips { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:32px; }
.proj-chip { display:flex; align-items:center; gap:6px; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:8px 14px; font-size:13px; color:var(--muted); }
.proj-chip strong { color:var(--text); font-weight:600; }
.proj-deliverables { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:24px 28px; margin-bottom:28px; }
.proj-del-title { font-family:'Syne',sans-serif; font-weight:700; font-size:14px; margin-bottom:16px; }
.proj-del-item { display:flex; align-items:flex-start; gap:12px; padding:10px 0; border-bottom:1px solid var(--border); }
.proj-del-item:last-child { border-bottom:none; padding-bottom:0; }
.proj-del-num { font-family:'Syne',sans-serif; font-weight:800; font-size:11px; color:var(--proj-accent,var(--accent)); min-width:20px; margin-top:2px; }
.proj-del-text { font-size:14px; color:var(--text); line-height:1.5; }
.proj-del-sub { font-size:12px; color:var(--muted); margin-top:2px; }
.proj-skills { display:flex; gap:8px; flex-wrap:wrap; }
.proj-skill { font-size:11px; font-weight:600; padding:4px 11px; border-radius:100px; background:var(--proj-accent-soft,rgba(108,99,255,0.08)); border:1px solid var(--proj-accent-border,rgba(108,99,255,0.2)); color:var(--proj-accent,var(--accent)); }

/* Gameplan */
.gp-step { display:flex; gap:20px; margin-bottom:8px; }
.gp-step-left { display:flex; flex-direction:column; align-items:center; flex-shrink:0; }
.gp-step-num { width:32px; height:32px; border-radius:50%; background:var(--proj-accent-soft,rgba(108,99,255,0.08)); border:1px solid var(--proj-accent-border,rgba(108,99,255,0.2)); display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-weight:800; font-size:12px; color:var(--proj-accent,var(--accent)); flex-shrink:0; }
.gp-step-line { width:1px; flex:1; background:var(--border); margin:4px 0; min-height:20px; }
.gp-step-right { padding-bottom:28px; flex:1; }
.gp-step-title { font-family:'Syne',sans-serif; font-weight:700; font-size:16px; margin-bottom:6px; }
.gp-step-desc { font-size:14px; color:var(--muted); line-height:1.7; margin-bottom:12px; }
.gp-prompt-box { background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:14px 16px; font-size:13px; color:var(--muted); line-height:1.65; font-style:italic; position:relative; }
.gp-prompt-box::before { content:'Try this prompt →'; position:absolute; top:-9px; left:12px; font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:var(--proj-accent,var(--accent)); background:var(--bg); padding:0 6px; font-style:normal; }
.gp-tip { background:rgba(108,99,255,0.05); border-left:3px solid var(--proj-accent,var(--accent)); border-radius:0 8px 8px 0; padding:11px 14px; margin-top:10px; font-size:13px; color:var(--muted); line-height:1.6; }
.gp-tip strong { color:var(--text); font-weight:500; }

/* Research / Build / Present tabs */
.tab-section { margin-bottom:36px; }
.tab-section-title { font-family:'Syne',sans-serif; font-weight:700; font-size:18px; margin-bottom:6px; }
.tab-section-sub { font-size:14px; color:var(--muted); line-height:1.6; margin-bottom:20px; }
.checklist { display:flex; flex-direction:column; gap:8px; }
.check-item { display:flex; align-items:flex-start; gap:12px; background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:13px 16px; cursor:pointer; transition:all 0.2s; }
.check-item:hover { border-color:rgba(255,255,255,0.12); }
.check-item.checked { border-color:rgba(0,212,170,0.25); background:rgba(0,212,170,0.03); }
.check-box { width:18px; height:18px; border-radius:4px; border:2px solid var(--border); flex-shrink:0; margin-top:1px; display:flex; align-items:center; justify-content:center; font-size:11px; transition:all 0.2s; }
.check-item.checked .check-box { background:var(--accent3); border-color:var(--accent3); color:white; }
.check-text { font-size:13px; color:var(--text); line-height:1.5; }
.check-sub { font-size:12px; color:var(--muted); margin-top:2px; }
.inline-sandbox { background:var(--bg); border:1px solid var(--border); border-radius:12px; overflow:hidden; margin:16px 0; }
.inline-sb-hd { display:flex; align-items:center; gap:7px; padding:10px 14px; border-bottom:1px solid var(--border); background:var(--surface); }
.inline-sb-title { font-size:12px; color:var(--muted); margin-left:4px; font-weight:500; }
.inline-sb-body { padding:14px; min-height:120px; max-height:200px; overflow-y:auto; display:flex; flex-direction:column; gap:10px; }
.inline-sb-row { display:flex; border-top:1px solid var(--border); }
.inline-sb-inp { flex:1; background:transparent; border:none; outline:none; padding:11px 14px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); }
.inline-sb-inp::placeholder { color:var(--muted); font-style:italic; }
.inline-sb-send { background:var(--proj-accent,var(--accent)); border:none; padding:0 16px; color:#0a0a0f; font-weight:700; font-size:13px; cursor:pointer; transition:opacity 0.2s; }
.inline-sb-send:hover { opacity:0.85; }

/* ══════════════════════════════════════
   PROJECT DETAIL PAGE
══════════════════════════════════════ */
#pg-proj-stock {
  --accent: #e8a820;
  --accent-glow: rgba(232,168,32,0.12);
  --accent-border: rgba(232,168,32,0.2);
}
#pg-proj-stock .topnav {
  background: rgba(10,10,8,0.92);
  border-bottom: 1px solid rgba(232,168,32,0.12);
}
#pg-proj-stock .logo span { color: #e8a820; }
#pg-proj-stock .crumb-dot { background: #e8a820; }
#pg-proj-stock .pill.xp { background:rgba(232,168,32,0.1); border-color:rgba(232,168,32,0.2); color:#e8a820; }

.proj-detail-layout { display:flex; flex:1; overflow:hidden; min-height:0; }

/* LEFT SIDEBAR - tab nav */
.proj-tabs-sidebar {
  width:200px; flex-shrink:0;
  background:var(--surface); border-right:1px solid var(--border);
  display:flex; flex-direction:column; padding:24px 0; overflow-y:auto;
}
.proj-tabs-sidebar::-webkit-scrollbar { display:none; }
.ptab-header { padding:0 20px 16px; border-bottom:1px solid var(--border); margin-bottom:12px; }
.ptab-course { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:4px; }
.ptab-title { font-family:'Syne',sans-serif; font-weight:700; font-size:13px; color:var(--text); line-height:1.3; }
.ptab {
  display:flex; align-items:center; gap:10px;
  padding:10px 20px; font-size:13px; color:var(--muted);
  cursor:pointer; transition:all 0.2s; position:relative;
  font-weight:500; border-left:2px solid transparent;
}
.ptab:hover { color:var(--text); background:rgba(255,255,255,0.02); }
.ptab.active { color:#e8a820; background:rgba(232,168,32,0.06); border-left-color:#e8a820; }
.ptab-icon { font-size:14px; flex-shrink:0; opacity:0.7; }
.ptab-done { margin-left:auto; width:16px; height:16px; border-radius:50%; background:rgba(0,212,170,0.2); border:1px solid rgba(0,212,170,0.3); display:flex; align-items:center; justify-content:center; font-size:8px; color:var(--accent3); }
.ptab-lock { margin-left:auto; font-size:11px; color:var(--muted); opacity:0.5; }

/* MAIN CONTENT */
.proj-detail-content { flex:1; overflow-y:auto; background:var(--bg); }
.proj-detail-content::-webkit-scrollbar { width:3px; }
.proj-detail-content::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.05); }

.ptab-panel { display:none; padding:44px 52px; max-width:780px; }
.ptab-panel.active { display:block; }

/* Overview panel */
.proj-hero { margin-bottom:40px; }
.proj-hero-tag { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:10px; }
.proj-hero-h { font-family:'Syne',sans-serif; font-weight:800; font-size:clamp(28px,4vw,44px); letter-spacing:-1.5px; line-height:1.1; margin-bottom:14px; }
.proj-hero-h .grad { background:linear-gradient(130deg,#e8a820,#f7c948); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.proj-hero-sub { font-size:15px; color:var(--muted); line-height:1.75; max-width:580px; }

.proj-meta-chips { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:36px; }
.pmchip { display:flex; align-items:center; gap:6px; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:7px 13px; font-size:12px; font-weight:500; color:var(--muted); }
.pmchip strong { color:#e8a820; font-weight:700; }

.proj-what-box { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:26px; margin-bottom:24px; position:relative; overflow:hidden; }
.proj-what-box::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,#e8a820,#f7c948); }
.proj-what-title { font-family:'Syne',sans-serif; font-weight:700; font-size:14px; color:var(--text); margin-bottom:14px; }
.proj-deliverable { display:flex; align-items:flex-start; gap:12px; margin-bottom:10px; }
.proj-deliverable:last-child { margin-bottom:0; }
.pd-num { font-family:'Syne',sans-serif; font-weight:800; font-size:11px; color:#e8a820; width:20px; flex-shrink:0; margin-top:2px; }
.pd-text { font-size:13px; color:var(--muted); line-height:1.55; }
.pd-text strong { color:var(--text); font-weight:500; }

.proj-skills { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px; }
.pskill { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:14px 16px; }
.pskill-name { font-family:'Syne',sans-serif; font-weight:700; font-size:13px; margin-bottom:3px; }
.pskill-desc { font-size:12px; color:var(--muted); line-height:1.4; }

/* Gameplan panel */
.gp-step { margin-bottom:28px; }
.gp-step-header { display:flex; align-items:center; gap:14px; margin-bottom:14px; }
.gp-num { font-family:'Syne',sans-serif; font-weight:800; font-size:11px; color:#e8a820; background:rgba(232,168,32,0.1); border:1px solid rgba(232,168,32,0.2); border-radius:6px; padding:4px 10px; flex-shrink:0; letter-spacing:1px; }
.gp-title { font-family:'Syne',sans-serif; font-weight:700; font-size:17px; }
.gp-desc { font-size:14px; color:var(--muted); line-height:1.7; margin-bottom:14px; }
.gp-prompt-box { background:var(--bg); border:1px solid rgba(232,168,32,0.15); border-left:3px solid #e8a820; border-radius:0 10px 10px 0; padding:14px 18px; margin-bottom:10px; }
.gp-prompt-label { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:7px; }
.gp-prompt-text { font-size:13px; color:var(--text); line-height:1.65; font-family:'DM Sans',sans-serif; }
.gp-prompt-text em { color:rgba(240,240,245,0.5); font-style:normal; }
.gp-tip { background:rgba(0,212,170,0.05); border:1px solid rgba(0,212,170,0.15); border-radius:9px; padding:12px 15px; font-size:13px; color:var(--muted); line-height:1.55; margin-bottom:4px; }
.gp-tip strong { color:var(--text); font-weight:500; }
.gp-divider { height:1px; background:var(--border); margin:28px 0; }

/* Generic tab panels */
.tab-label { font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:12px; }
.tab-h { font-family:'Syne',sans-serif; font-weight:700; font-size:clamp(22px,3vw,34px); letter-spacing:-1px; line-height:1.1; margin-bottom:12px; }
.tab-body { font-size:15px; color:var(--muted); line-height:1.8; margin-bottom:20px; }
.tab-body strong { color:var(--text); font-weight:500; }

/* Research sandbox */
.research-sandbox { background:var(--bg); border:1px solid var(--border); border-radius:14px; overflow:hidden; margin-bottom:16px; }
.rs-header { display:flex; align-items:center; gap:8px; padding:12px 16px; border-bottom:1px solid var(--border); background:var(--surface); }
.rs-title { font-size:12px; color:var(--muted); font-weight:500; }
.rs-badge { margin-left:auto; background:rgba(232,168,32,0.1); border:1px solid rgba(232,168,32,0.2); border-radius:100px; padding:3px 9px; font-size:10px; font-weight:600; color:#e8a820; letter-spacing:1px; text-transform:uppercase; }
.rs-body { padding:16px; display:flex; flex-direction:column; gap:11px; min-height:160px; max-height:260px; overflow-y:auto; }
.rs-hint { font-size:12px; color:var(--muted); line-height:1.5; }

/* Notebook in project */
.proj-notebook { background:var(--surface); border:1px solid rgba(232,168,32,0.15); border-radius:14px; padding:22px; margin-top:24px; }
.proj-notebook-title { font-family:'Syne',sans-serif; font-weight:700; font-size:13px; color:var(--text); margin-bottom:4px; }
.proj-notebook-sub { font-size:11px; color:var(--muted); margin-bottom:14px; }

/* ══════════════════════════════════════
   PROJECT DETAIL PAGE
══════════════════════════════════════ */
#pg-stock {
  --accent: #e8a820;
  --accent-glow: rgba(232,168,32,0.15);
}
#pg-stock .topnav { background:rgba(10,10,8,0.92); border-bottom:1px solid rgba(232,168,32,0.12); }
#pg-stock .logo span { color:#e8a820; }
#pg-stock .crumb-dot { background:#e8a820; }
#pg-stock .pill.xp { background:rgba(232,168,32,0.1); border-color:rgba(232,168,32,0.2); color:#e8a820; }

/* TAB RAIL — left side */
.proj-tab-rail {
  width:200px; flex-shrink:0;
  background:var(--surface); border-right:1px solid var(--border);
  display:flex; flex-direction:column; padding:24px 0; overflow-y:auto;
  align-self:stretch;
}
.proj-tab-rail::-webkit-scrollbar { display:none; }
.ptab-section-lbl { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--muted); padding:0 18px; margin-bottom:8px; margin-top:20px; }
.ptab-section-lbl:first-child { margin-top:0; }
.ptab {
  display:flex; align-items:center; gap:10px;
  padding:10px 18px; font-size:13px; color:var(--muted);
  cursor:pointer; transition:all 0.18s; border-left:2px solid transparent;
  font-family:'DM Sans',sans-serif; font-weight:500;
}
.ptab:hover { color:var(--text); background:rgba(255,255,255,0.03); }
.ptab.active { color:#e8a820; border-left-color:#e8a820; background:rgba(232,168,32,0.05); font-weight:600; }
.ptab.done { color:var(--accent3); }
.ptab.done::after { content:'✓'; margin-left:auto; font-size:11px; }
.ptab-num { width:20px; height:20px; border-radius:5px; background:var(--surface2); display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:var(--muted); flex-shrink:0; }
.ptab.active .ptab-num { background:rgba(232,168,32,0.15); color:#e8a820; }
/* MAIN CONTENT */
.proj-detail-content { flex:1; overflow-y:auto; background:var(--bg); }
.proj-detail-content::-webkit-scrollbar { width:3px; }
.proj-detail-content::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.05); }
.proj-tab-panel { display:none; padding:48px 56px; max-width:720px; min-height:100%; }
.proj-tab-panel.active { display:block; }
.proj-tab-title { font-family:'Syne',sans-serif; font-weight:800; font-size:clamp(24px,3.5vw,38px); letter-spacing:-1px; line-height:1.1; margin-bottom:10px; }
.proj-tab-sub { font-size:15px; color:var(--muted); line-height:1.7; margin-bottom:28px; }
.proj-instr { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px 22px; margin-bottom:14px; position:relative; overflow:hidden; }
.proj-instr::before { content:''; position:absolute; top:0; left:0; bottom:0; width:3px; background:#e8a820; }
.proj-instr-step { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:6px; }
.proj-instr-text { font-size:14px; color:var(--text); line-height:1.7; }
.proj-instr-text em { color:var(--accent3); font-style:normal; font-weight:600; }
.proj-sandbox { background:var(--bg); border:1px solid var(--border); border-radius:13px; overflow:hidden; margin-bottom:12px; }
.proj-sb-hd { display:flex; align-items:center; gap:7px; padding:11px 15px; border-bottom:1px solid var(--border); background:var(--surface); }
.proj-sb-body { padding:16px; display:flex; flex-direction:column; gap:11px; min-height:180px; max-height:280px; overflow-y:auto; }
.proj-sb-inp-row { display:flex; border-top:1px solid var(--border); }
.proj-sb-inp { flex:1; background:transparent; border:none; outline:none; padding:13px 16px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); }
.proj-sb-inp::placeholder { color:var(--muted); }
.proj-sb-send { background:#e8a820; border:none; padding:0 20px; color:#0a0a0f; font-size:15px; font-weight:700; cursor:pointer; transition:opacity 0.2s; }
.proj-sb-send:hover { opacity:0.85; }
.proj-deliverable { background:rgba(232,168,32,0.05); border:1px solid rgba(232,168,32,0.2); border-radius:12px; padding:18px 20px; margin-bottom:12px; }
.proj-deliverable-lbl { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#e8a820; margin-bottom:8px; }
.proj-deliverable textarea { width:100%; min-height:100px; background:var(--bg); border:1px solid rgba(232,168,32,0.2); border-radius:8px; padding:11px 13px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); outline:none; resize:none; line-height:1.6; transition:border-color 0.2s; box-sizing:border-box; }
.proj-deliverable textarea:focus { border-color:rgba(232,168,32,0.5); }
.proj-deliverable textarea::placeholder { color:var(--muted); font-style:italic; }
.proj-nav-btns { display:flex; gap:10px; margin-top:32px; }
.proj-next-btn { background:#e8a820; color:#0a0a0f; border:none; padding:12px 24px; border-radius:10px; font-family:'DM Sans',sans-serif; font-size:14px; font-weight:700; cursor:pointer; transition:all 0.2s; }
.proj-next-btn:hover { opacity:0.88; transform:translateY(-1px); }
.proj-back-btn { background:transparent; color:var(--muted); border:1px solid var(--border); padding:12px 24px; border-radius:10px; font-family:'DM Sans',sans-serif; font-size:14px; cursor:pointer; transition:all 0.2s; }
.proj-back-btn:hover { color:var(--text); }

/* ── COURSE SELECTOR ── */
#pg-courses /* ── CURRICULUM PAGE ── */
.curr-page{overflow-y:auto;height:calc(100vh - 52px);padding:52px 48px 0;}
.curr-hero{margin-bottom:48px;max-width:680px;}
.curr-hero-label{font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent);margin-bottom:14px;}
.curr-hero-h{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);letter-spacing:-2px;line-height:1.05;margin-bottom:14px;}
.curr-hero-sub{font-size:16px;color:var(--muted);line-height:1.65;margin-bottom:18px;}
.curr-any-order{display:inline-block;font-size:12px;color:var(--accent3);font-weight:600;background:rgba(0,212,170,0.08);border:1px solid rgba(0,212,170,0.2);border-radius:100px;padding:5px 14px;}
.curr-grid{display:grid;grid-template-columns:1fr 380px;gap:20px;align-items:start;}
@media(max-width:900px){.curr-grid{grid-template-columns:1fr;}}

/* Live course card */
.curr-card{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:28px;position:relative;overflow:hidden;transition:all 0.25s;}
.curr-live{border-color:rgba(0,212,170,0.2);cursor:pointer;}
.curr-live:hover{border-color:rgba(0,212,170,0.4);transform:translateY(-3px);box-shadow:0 20px 60px rgba(0,0,0,0.3);}
.curr-live::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent3),var(--accent));}
.curr-card-glow{position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(0,212,170,0.06) 0%,transparent 70%);pointer-events:none;}
.curr-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.curr-card-icon{font-size:28px;}
.curr-card-badge{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:4px 10px;border-radius:100px;}
.curr-card-badge.live{background:rgba(0,212,170,0.12);border:1px solid rgba(0,212,170,0.25);color:var(--accent3);}
.curr-card-badge.soon{background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--muted);}
.curr-card-tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ccc);margin-bottom:8px;}
.curr-card-title{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;letter-spacing:-0.5px;margin-bottom:10px;}
.curr-card-desc{font-size:13px;color:var(--muted);line-height:1.65;margin-bottom:22px;}

/* Module list inside live card */
.curr-card-modules{display:flex;flex-direction:column;gap:6px;margin-bottom:24px;background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:14px 16px;}
.curr-mod-row{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--muted);}
.curr-mod-row span:nth-child(2){flex:1;color:var(--text);}
.curr-mod-dot{width:8px;height:8px;border-radius:50%;border:2px solid var(--border);background:transparent;flex-shrink:0;}
.curr-mod-dot.done{background:var(--accent3);border-color:var(--accent3);}
.curr-mod-dot.active{background:var(--accent);border-color:var(--accent);box-shadow:0 0 6px rgba(108,99,255,0.5);}
.curr-mod-time{font-size:11px;color:var(--muted);white-space:nowrap;}

/* Card footer */
.curr-card-footer{display:flex;align-items:center;justify-content:space-between;gap:12px;}
.curr-card-stats{display:flex;gap:14px;font-size:11px;color:var(--muted);}
.curr-start-btn{background:var(--accent3);color:#0a0a0f;border:none;border-radius:10px;padding:10px 22px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.curr-start-btn:hover{opacity:0.85;transform:translateX(3px);}

/* Right column */
.curr-col-right{display:flex;flex-direction:column;gap:14px;}
.curr-soon{opacity:0.75;}
.curr-soon:hover{opacity:0.9;}
.curr-card-footer-soon{font-size:11px;color:var(--muted);margin-top:12px;}

/* Projects banner */
.curr-projects-card{background:linear-gradient(135deg,rgba(247,201,72,0.06),rgba(108,99,255,0.04));border:1px solid rgba(247,201,72,0.15);border-radius:16px;padding:22px;cursor:pointer;transition:all 0.2s;}
.curr-projects-card:hover{border-color:rgba(247,201,72,0.3);transform:translateY(-2px);}
.curr-proj-arrow{font-size:12px;font-weight:600;color:var(--yellow);margin-top:12px;}

/* Legacy course-card (used on other pages) */
.course-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px 26px;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;margin-bottom:12px;}
#pg-courses .course-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--cc);}
#pg-courses .course-card:hover{border-color:rgba(255,255,255,0.12);transform:translateX(4px);}
#pg-courses .cc-tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--cc);margin-bottom:8px;}
#pg-courses .cc-title{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;letter-spacing:-0.5px;margin-bottom:6px;}
#pg-courses .cc-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
#pg-courses .cc-meta{display:flex;align-items:center;gap:14px;font-size:12px;color:var(--muted);}
#pg-courses .cc-meta span{display:flex;align-items:center;gap:5px;}
#pg-courses .cc-badge{margin-left:auto;font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;}
#pg-courses .cc-badge.live{background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
#pg-courses .cc-badge.soon{background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--muted);}

/* ── MODULE OVERVIEW PAGE ── */
.mod-ov-layout{max-width:720px;margin:0 auto;padding:52px 40px;overflow-y:auto;height:calc(100vh - 52px);}
.mod-ov-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.22);border-radius:100px;padding:5px 14px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#a09aff;margin-bottom:20px;}
.mod-ov-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(28px,4vw,44px);letter-spacing:-1.5px;line-height:1.1;margin-bottom:12px;}
.mod-ov-desc{font-size:16px;color:var(--muted);line-height:1.75;margin-bottom:28px;}
.mod-ov-stats{display:flex;gap:12px;margin-bottom:36px;flex-wrap:wrap;}
.mod-ov-stat{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:14px 18px;flex:1;min-width:100px;}
.mod-ov-stat{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;text-align:center;transition:transform 0.15s;}
.mod-ov-stat:hover{transform:translateY(-2px);}
.mod-ov-stat-n{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:var(--accent);margin-bottom:4px;letter-spacing:-0.5px;}
.mod-ov-stat-l{font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);}
.mod-ov-sections{display:flex;flex-direction:column;gap:8px;margin-bottom:32px;}
.mod-ov-sec{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:14px 18px;display:flex;align-items:center;gap:14px;}
.mod-ov-sec-num{font-family:'Syne',sans-serif;font-weight:800;font-size:11px;color:var(--accent);min-width:28px;}
.mod-ov-sec-info{flex:1;}
.mod-ov-sec-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:2px;}
.mod-ov-sec-meta{font-size:12px;color:var(--muted);}
.mod-ov-start{background:var(--accent);color:white;border:none;padding:14px 32px;border-radius:11px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 0 24px rgba(108,99,255,0.3);transition:all 0.2s;}
.mod-ov-start:hover{transform:translateY(-2px);box-shadow:0 0 36px rgba(108,99,255,0.45);}

/* ── AI CHAT POPUP ── */
.ai-popup-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:800;opacity:0;pointer-events:none;transition:opacity 0.25s;}
.ai-popup-overlay.open{opacity:1;pointer-events:all;}
.ai-popup{position:fixed;bottom:0;right:0;width:420px;height:80vh;background:var(--surface);border-top:1px solid var(--border);border-left:1px solid var(--border);border-radius:18px 0 0 0;display:flex;flex-direction:column;z-index:900;transform:translateY(100%);transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);pointer-events:none;}
.ai-popup.open{transform:translateY(0);pointer-events:all;}
.ai-popup-hd{display:flex;align-items:center;gap:10px;padding:16px 20px;border-bottom:1px solid var(--border);flex-shrink:0;}
.ai-popup-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;flex:1;}
.ai-popup-ctx{font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px;background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.2);color:var(--accent3);}
.ai-popup-close{width:28px;height:28px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--muted);transition:all 0.2s;flex-shrink:0;}
.ai-popup-close:hover{color:var(--text);}
.ai-popup-msgs{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:12px;}
.ai-popup-msgs::-webkit-scrollbar{width:2px;}
.ai-popup-msgs::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);}
.ai-msg{display:flex;gap:8px;align-items:flex-start;animation:fadeUp 0.25s ease both;}
.ai-msg-role{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 7px;border-radius:4px;white-space:nowrap;margin-top:3px;flex-shrink:0;}
.ai-msg-role.you{background:rgba(108,99,255,0.15);color:#a09aff;}
.ai-msg-role.ai{background:rgba(0,212,170,0.1);color:var(--accent3);}
.ai-msg-text{font-size:13px;color:var(--text);line-height:1.65;}
.ai-msg-text.dim{color:var(--muted);}
.ai-popup-inp-row{display:flex;border-top:1px solid var(--border);flex-shrink:0;}
.ai-popup-inp{flex:1;background:transparent;border:none;outline:none;padding:14px 16px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);}
.ai-popup-inp::placeholder{color:var(--muted);}
.ai-popup-send{background:var(--accent);border:none;padding:0 20px;color:white;font-size:15px;font-weight:700;cursor:pointer;transition:opacity 0.2s;border-radius:0 0 0 0;}
.ai-popup-send:hover{opacity:0.85;}
.ai-popup-hint{padding:8px 20px;font-size:11px;color:var(--muted);border-top:1px solid var(--border);flex-shrink:0;line-height:1.4;}

.nb-course-panel{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0;height:0;}
.nb-course-panel.active{display:flex;flex-direction:column;flex:1;min-height:0;}
.nb-mod-tabs{display:flex;gap:2px;padding:10px 24px 0;overflow-x:auto;flex-shrink:0;background:rgba(255,255,255,0.02);border-bottom:1px solid rgba(255,255,255,0.05);min-height:0;}
.nb-mod-tabs::-webkit-scrollbar{display:none;}
.nb-mod-tab{padding:7px 14px;border-radius:7px 7px 0 0;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all 0.15s;position:relative;top:1px;border:1px solid transparent;border-bottom:none;}
.nb-mod-tab:hover{color:var(--text);}
.nb-mod-tab.active{background:var(--bg);border-color:rgba(255,255,255,0.06);color:var(--text);}
.nb-mod-panel{display:none;flex:1;min-height:0;overflow:hidden;}
.nb-mod-panel.active{display:flex;flex-direction:column;overflow-y:auto;}
.nb-mod-panel::-webkit-scrollbar{width:3px;}
.nb-mod-panel::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.07);}
.nb-body-inner{display:flex;flex-direction:column;gap:14px;padding:18px 24px 80px;}
.nb-sec-block{background:var(--surface);border:1px solid rgba(255,255,255,0.06);border-radius:13px;padding:16px 18px;display:flex;flex-direction:column;gap:10px;}
.nb-free-block{background:transparent;border-color:rgba(255,255,255,0.04);}
.nb-sec-header{margin-bottom:2px;}
.nb-sec-tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent);}
.nb-q-row{display:flex;flex-direction:column;gap:5px;}
.nb-q-text{font-size:13px;color:var(--muted);line-height:1.5;}
.nb-input{background:var(--bg);border:1px solid rgba(255,255,255,0.07);border-radius:9px;padding:10px 13px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);width:100%;resize:vertical;min-height:70px;outline:none;line-height:1.65;transition:border-color 0.2s;}
.nb-input:focus{border-color:rgba(108,99,255,0.4);}
.nb-input::placeholder{color:rgba(122,122,154,0.5);}
.nb-free-input{min-height:120px;resize:vertical;}

.age-card{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:32px 28px;display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;transition:all 0.25s;}
.age-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--ac, var(--border));transition:opacity 0.3s;}
.age-live{--ac:var(--accent);cursor:pointer;}
.age-live:hover{transform:translateY(-4px);border-color:rgba(108,99,255,0.3);box-shadow:0 12px 40px rgba(108,99,255,0.12);}
.age-soon{opacity:0.5;}
.age-card-range{font-family:'Syne',sans-serif;font-weight:800;font-size:32px;color:var(--text);letter-spacing:-1px;}
.age-card-name{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;}
.age-card-desc{font-size:13px;color:var(--muted);line-height:1.6;flex:1;}
.age-card-badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:4px 11px;border-radius:100px;background:rgba(255,255,255,0.06);color:var(--muted);width:fit-content;}
.age-card-badge.live{background:rgba(108,99,255,0.12);color:#a09aff;border:1px solid rgba(108,99,255,0.2);}
.age-card-live-dot{position:absolute;top:20px;right:20px;width:8px;height:8px;border-radius:50%;background:var(--accent3);animation:pulse 2s infinite;}

.uc-toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:13px 22px;font-size:13px;font-weight:500;color:var(--text);z-index:1000;opacity:0;transition:all 0.25s;pointer-events:none;white-space:nowrap;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.uc-toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.uc-toast span{color:var(--accent3);}

/* ── MODULE OUTLINE ── */
.outline{padding:52px 60px;background:var(--surface);border-top:1px solid var(--border);}
.outline-inner{max-width:640px;}
.outline-hd{display:flex;align-items:center;gap:14px;margin-bottom:32px;}
.outline-badge{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;background:rgba(108,99,255,0.12);border:1px solid rgba(108,99,255,0.2);color:#a09aff;padding:4px 12px;border-radius:100px;}
.outline-title{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;letter-spacing:-0.5px;}
.outline-block{margin-bottom:28px;}
.outline-block-lbl{font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
.outline-term-row{display:flex;gap:0;border-bottom:1px solid rgba(255,255,255,0.04);padding:9px 0;}
.outline-term-row:last-child{border-bottom:none;}
.outline-term{font-size:13px;font-weight:700;color:var(--text);min-width:160px;flex-shrink:0;}
.outline-def{font-size:13px;color:var(--muted);line-height:1.55;}
.outline-concept-row{display:flex;gap:12px;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.outline-concept-row:last-child{border-bottom:none;}
.outline-concept-dot{width:6px;height:6px;border-radius:50%;background:var(--accent3);flex-shrink:0;margin-top:6px;}
.outline-concept-txt{font-size:13px;color:var(--muted);line-height:1.6;}
.outline-concept-txt strong{color:var(--text);}
.outline-formula{background:var(--bg);border:1px solid rgba(255,255,255,0.07);border-radius:11px;padding:16px 18px;margin-bottom:8px;}
.outline-formula-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
.outline-fp{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:700;}
.outline-fp.role{background:rgba(108,99,255,0.15);color:#a09aff;}
.outline-fp.task{background:rgba(0,212,170,0.12);color:var(--accent3);}
.outline-fp.ctx{background:rgba(255,107,107,0.1);color:var(--accent2);}
.outline-fp.fmt{background:rgba(247,201,72,0.1);color:var(--yellow);}
.outline-fp.plus{color:var(--muted);font-size:14px;font-weight:300;}
.outline-ex{font-size:12px;color:var(--muted);line-height:1.65;font-style:italic;border-left:2px solid rgba(108,99,255,0.3);padding-left:12px;}
.outline-ex-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.outline-ex-card{background:var(--bg);border:1px solid rgba(255,255,255,0.06);border-radius:9px;padding:12px 14px;}
.outline-ex-lbl{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.outline-ex-text{font-size:12px;color:var(--text);line-height:1.55;font-style:italic;}
/* ── DEBATE COACH / EMAIL WORKSHOP ── */
.proj-err{background:rgba(255,107,107,0.1);border:1px solid rgba(255,107,107,0.25);color:var(--accent2);border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:12px;}
/* ── DEBATE COACH ── */
.debate-chip{background:var(--surface);border:1px solid var(--border);border-radius:100px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:all 0.2s;white-space:nowrap;display:inline-block;}
.debate-chip:hover{border-color:rgba(108,99,255,0.4);color:var(--accent);}
.debate-chip.selected{background:rgba(108,99,255,0.12);border-color:var(--accent);color:var(--accent);}
.db-msg{display:flex;flex-direction:column;gap:3px;max-width:88%;}
.db-msg.user{align-self:flex-end;}
.db-msg.ai{align-self:flex-start;}
.db-msg-label{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;}
.db-msg.user .db-msg-label{color:var(--accent);text-align:right;}
.db-msg.ai .db-msg-label{color:var(--accent2);}
.db-msg-text{border-radius:10px;padding:10px 14px;font-size:13px;line-height:1.6;}
.db-msg.user .db-msg-text{background:rgba(108,99,255,0.12);border:1px solid rgba(108,99,255,0.25);color:var(--text);}
.db-msg.ai .db-msg-text{background:var(--surface);border:1px solid rgba(255,107,107,0.2);color:var(--muted);}
/* ── EMAIL WORKSHOP ── */
.em-type-btn{background:var(--surface);border:2px solid var(--border);border-radius:12px;padding:14px 16px;cursor:pointer;font-size:13px;font-weight:700;color:var(--text);transition:all 0.2s;line-height:1.4;}
.em-type-btn:hover{border-color:rgba(0,212,170,0.35);color:var(--accent3);}
.em-type-btn.selected{border-color:var(--accent3);background:rgba(0,212,170,0.06);color:var(--accent3);}
.em-quick-fix{background:var(--surface);border:1px solid var(--border);border-radius:100px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:all 0.2s;font-family:\'DM Sans\',sans-serif;}
.em-quick-fix:hover{border-color:rgba(0,212,170,0.4);color:var(--accent3);}
</style>
</head>
<body>

<!-- ════════════════════════════════
     PAGE 1: HOMEPAGE
════════════════════════════════ -->
<div id="pg-courses" class="page">
  <div class="topnav">
    <span class="logo" onclick="nav('home')">Prompt<span>Lit</span></span>
    <span class="nav-sep">/</span>
    <div class="nav-crumbs">
      <span class="crumb active"><span class="crumb-dot cur"></span> Curriculum</span>
    </div>
    <div class="nav-right">
      <div class="pill xp" onclick="nav('profile')" style="cursor:pointer;">⚡ 340 XP
      <div class="profile-pill" onclick="nav('profile')">👤 Profile</div></div>
      <div class="pill streak">🔥 7</div>
    </div>
  </div>

  <div class="curr-page">

    <!-- HERO -->
    <div class="curr-hero">
      <div class="curr-hero-label">Full Curriculum</div>
      <h1 class="curr-hero-h">Four pillars.<br><span class="grad">One complete education.</span></h1>
      <p class="curr-hero-sub">Start anywhere. No prerequisites. Every course is free and self-contained.</p>
      <div class="curr-any-order">✦ Complete in any order</div>
    </div>

    <!-- COURSE GRID -->
    <div class="curr-grid">

      <!-- Prompting 101 — LIVE -->
      <div class="curr-card curr-live" onclick="nav('course')" style="--ccc:var(--accent3);">
        <div class="curr-card-glow"></div>
        <div class="curr-card-top">
          <div class="curr-card-icon">✍️</div>
          <div class="curr-card-badge live">● Live Now</div>
        </div>
        <div class="curr-card-tag">Core Skill · Prompting</div>
        <div class="curr-card-title">Prompting 101</div>
        <div class="curr-card-desc">The most important AI skill nobody teaches. Write prompts that actually work — with a live AI sandbox in every module.</div>
        <div class="curr-card-modules">
          <div class="curr-mod-row"><div class="curr-mod-dot done"></div><span>M1 · What is a Prompt?</span><span class="curr-mod-time">8 min</span></div>
          <div class="curr-mod-row"><div class="curr-mod-dot done"></div><span>M2 · Good vs. Bad Prompts</span><span class="curr-mod-time">9 min</span></div>
